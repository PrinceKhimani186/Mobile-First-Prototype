# ══════════════════════════════════════════════════════════════════════════════
# App Squad — environment variables
# Copy to `.env` and fill in values. `.env` is gitignored; never commit secrets.
# Loaded by run-all.ps1 / run-dev.ps1 for local development.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core (REQUIRED for local development) ────────────────────────────────────
# Local PostgreSQL connection (staff/admin side: projects, admin_users, assignments)
DATABASE_URL=
# Express session signing secret (any random string locally)
SESSION_SECRET=

# ── Supabase (REQUIRED for client onboarding flow after payment) ─────────────
# customer_enrollment / app_users records live here
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (REQUIRED for real checkout; dev mocks checkout when key is empty) ─
# Use sk_test_... locally. sk_live_... only in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Server-side price IDs (must match the mode — test/live — of the key above)
STRIPE_PRICE_ESSENTIALS=
STRIPE_PRICE_ACCELERATOR=
STRIPE_PRICE_EMPIRE=
STRIPE_PRICE_ESSENTIALS_MONTHLY=
STRIPE_PRICE_ACCELERATOR_MONTHLY=
STRIPE_PRICE_EMPIRE_MONTHLY=
STRIPE_PRICE_ESSENTIALS_SETUP=
STRIPE_PRICE_ACCELERATOR_SETUP=
STRIPE_PRICE_EMPIRE_SETUP=
# Frontend copies (read by app-squad enrollment page via import.meta.env)
VITE_STRIPE_PRICE_ESSENTIALS=
VITE_STRIPE_PRICE_ACCELERATOR=
VITE_STRIPE_PRICE_EMPIRE=
VITE_STRIPE_PRICE_ESSENTIALS_MONTHLY=
VITE_STRIPE_PRICE_ACCELERATOR_MONTHLY=
VITE_STRIPE_PRICE_EMPIRE_MONTHLY=
VITE_STRIPE_PRICE_ESSENTIALS_SETUP=
VITE_STRIPE_PRICE_ACCELERATOR_SETUP=
VITE_STRIPE_PRICE_EMPIRE_SETUP=

# ── Zoho Sign (agreement e-signature step) ───────────────────────────────────
# Code accepts ZOHO_SIGN_* first, then falls back to the ZOHO_* names.
ZOHO_SIGN_CLIENT_ID=
ZOHO_SIGN_CLIENT_SECRET=
ZOHO_SIGN_REFRESH_TOKEN=
ZOHO_SIGN_ORGANIZATION_ID=
ZOHO_SIGN_WEBHOOK_SECRET=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_SIGN_ORG_ID=
ZOHO_REGION=
ZOHO_OAUTH_REDIRECT_URI=
# Plan → agreement template mapping. ID is preferred (survives renames);
# NAME is the fallback and is matched leniently (case/underscores/hyphens/spaces).
# List your account's templates at GET /api/zoho/templates.
ZOHO_TEMPLATE_ESSENTIALS_ID=
ZOHO_TEMPLATE_ESSENTIALS_NAME=
ZOHO_TEMPLATE_ACCELERATOR_ID=
ZOHO_TEMPLATE_ACCELERATOR_NAME=
ZOHO_TEMPLATE_EMPIRE_ID=
ZOHO_TEMPLATE_EMPIRE_NAME=

# ── GoHighLevel CRM (optional — contact sync is non-fatal when missing) ──────
GHL_API_KEY=
GHL_LOCATION_ID=

# ── ClickUp (optional — project/task sync) ───────────────────────────────────
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=

# ── Admin / staff access ─────────────────────────────────────────────────────
# Password used when seeding the default admin accounts (api-server /admin/login)
ADMIN_PASSWORD=
# Staff login credentials checked client-side in app-squad staff-login page
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# ── Runtime config (set automatically by run-all.ps1 / run-dev.ps1) ──────────
#PORT=
#API_SERVER_PORT=8080
#BASE_PATH=/
#NODE_ENV=development
#LOG_LEVEL=info

# ── Replit platform (set by Replit automatically; not needed locally) ────────
#REPL_ID=
#REPLIT_DOMAINS=

# ── Legacy / currently unused by code (kept for reference) ───────────────────
# Monday.com — token exists in Replit config but no code reads it today
#MONDAY_API_TOKEN=
#MONDAY_BOARD_ID=
# eSignatures.io — replaced by Zoho Sign; no code reads these today
#ESIGNATURES_TOKEN=
#ESIGNATURES_TEMPLATE_ESSENTIALS=
#ESIGNATURES_TEMPLATE_ACCELERATOR=
#ESIGNATURES_TEMPLATE_EMPIRE=
# Old Starter/Growth plans — no code reads these today
#STRIPE_PRICE_STARTER=
#STRIPE_PRICE_STARTER_MONTHLY=
#STRIPE_PRICE_STARTER_SETUP=
#STRIPE_PRICE_GROWTH=
#STRIPE_PRICE_GROWTH_MONTHLY=
#STRIPE_PRICE_GROWTH_SETUP=
